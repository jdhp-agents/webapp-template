<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="{{ PROJECT_NAME }} - Settings">

    <title>{{ PROJECT_NAME }} - Settings</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">  <!-- See https://icons.getbootstrap.com/#install -->
</head>
<body>
    <!-- Navbar will be inserted here by navbar.js -->

    <div class="container mt-4">
        <div class="row">
            <div class="col-md-8 offset-md-2">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-gear me-2"></i>Settings
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-12">
                                <div class="d-grid">
                                    <button id="downloadUserData" class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#downloadModal">
                                        <i class="bi bi-download me-2"></i>Download User Data
                                    </button>
                                </div>
                            </div>
                            <div class="col-12">
                                <small class="text-muted">
                                    Download your data as an archive containing your database and media files.
                                </small>
                            </div>
                            <div class="col-12">
                                <hr>
                            </div>
                            <div class="col-12">
                                <div class="d-grid">
                                    <button id="importUserData" class="btn btn-warning" type="button" data-bs-toggle="modal" data-bs-target="#importModal">
                                        <i class="bi bi-upload me-2"></i>Import User Data
                                    </button>
                                </div>
                            </div>
                            <div class="col-12">
                                <small class="text-muted">
                                    Import your data from an archive (.zip, .tar.gz, or .tar.xz). <strong>Warning:</strong> Keep the most recently updated version of each {{ MAIN_MODEL_CLASS_NAME|lower }}.
                                </small>
                            </div>
                            <div class="col-12">
                                <hr>
                            </div>
                            <div class="col-12">
                                <div class="d-grid">
                                    <button id="deleteUserData" class="btn btn-danger" type="button" data-bs-toggle="modal" data-bs-target="#deleteModal">
                                        <i class="bi bi-trash me-2"></i>Delete All User Data
                                    </button>
                                </div>
                            </div>
                            <div class="col-12">
                                <small class="text-muted">
                                    <strong>Danger Zone:</strong> Permanently delete all your {{ MAIN_MODEL_CLASS_NAME|lower }}s and their data. This action cannot be undone.
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Download Modal -->
    <div class="modal fade" id="downloadModal" tabindex="-1" aria-labelledby="downloadModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="downloadModalLabel">
                        <i class="bi bi-download me-2"></i>Download User Data
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="downloadForm">
                        <div class="mb-3">
                            <label for="filename" class="form-label">Filename</label>
                            <div class="input-group">
                                <input type="text" class="form-control" id="filename" placeholder="{{ MAIN_MODEL_CLASS_NAME|lower }}_user_data" required>
                                <span class="input-group-text">.</span>
                                <select class="form-select" id="archiveFormat" style="max-width: 120px;" aria-label="Select archive format">
                                    <option value="zip" selected>zip</option>
                                    <option value="tar.gz">tar.gz</option>
                                    <option value="tar.xz">tar.xz</option>
                                </select>
                            </div>
                            <div class="form-text">
                                Choose a filename and format for your data export.
                                <br><strong>ZIP</strong>: Universal compatibility
                                <br><strong>TAR.GZ</strong>: Good compression
                                <br><strong>TAR.XZ</strong>: Best compression
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="confirmDownload">
                        <i class="bi bi-download me-2"></i>Download
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Import Modal -->
    <div class="modal fade" id="importModal" tabindex="-1" aria-labelledby="importModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="importModalLabel">
                        <i class="bi bi-upload me-2"></i>Import User Data
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-warning" role="alert">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <strong>Warning:</strong> Importing data will replace your current database and media files. This action cannot be undone.
                    </div>
                    <form id="importForm">
                        <div class="mb-3">
                            <label for="importFile" class="form-label">Select Archive File</label>
                            <input type="file" class="form-control" id="importFile" accept=".zip,.tar.gz,.tar.xz" required>
                            <div class="form-text">
                                Supported formats: ZIP (.zip), TAR.GZ (.tar.gz), TAR.XZ (.tar.xz)
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-warning" id="confirmImport">
                        <i class="bi bi-upload me-2"></i>Import Data
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Delete Modal -->
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="deleteModalLabel">
                        <i class="bi bi-exclamation-triangle me-2"></i>Delete All User Data
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-danger" role="alert">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <strong>Danger:</strong> This action will permanently delete ALL your data including:
                        <ul class="mt-2 mb-0">
                            <li>All {{ MAIN_MODEL_CLASS_NAME|lower }}s and their data</li>
                        </ul>
                    </div>
                    <p class="mb-3">
                        <strong>This action cannot be undone.</strong> Make sure you have exported your data if you want to keep a backup.
                    </p>
                    <p class="mb-0">
                        Type <strong>DELETE</strong> in the field below to confirm this action:
                    </p>
                    <div class="mt-3">
                        <input type="text" class="form-control" id="deleteConfirmationInput" placeholder="Type DELETE to confirm">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" id="confirmDelete" disabled>
                        <i class="bi bi-trash me-2"></i>Delete All Data
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS and dependencies -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    <!-- Navbar component -->
    <script src="js/navbar.js"></script>

    <script type="module">
        /**
         * Generate default filename with current timestamp
         */
        function generateDefaultFilename() {
            const now = new Date();
            const year = now.getFullYear();
            const month = String(now.getMonth() + 1).padStart(2, '0');
            const day = String(now.getDate()).padStart(2, '0');
            const hours = String(now.getHours()).padStart(2, '0');
            const minutes = String(now.getMinutes()).padStart(2, '0');
            const seconds = String(now.getSeconds()).padStart(2, '0');
            
            return `{{ MAIN_MODEL_CLASS_NAME|lower }}_user_data_${year}-${month}-${day}_${hours}-${minutes}-${seconds}`;
        }

        /**
         * Handle download user data confirmation from modal
         */
        async function handleDownloadUserData() {
            const confirmButton = document.getElementById('confirmDownload');
            const formatSelect = document.getElementById('archiveFormat');
            const filenameInput = document.getElementById('filename');
            const selectedFormat = formatSelect.value;
            const filename = filenameInput.value.trim();
            const originalHtml = confirmButton.innerHTML;
            
            // Validate filename
            if (!filename) {
                const alertDiv = document.createElement('div');
                alertDiv.className = 'alert alert-danger alert-dismissible fade show';
                alertDiv.innerHTML = `
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Please enter a filename.
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                `;
                document.querySelector('#downloadModal .modal-body').appendChild(alertDiv);
                return;
            }
            
            try {
                // Show loading state
                confirmButton.disabled = true;
                confirmButton.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Downloading...';
                
                // Build the URL with filename and format parameters
                const params = new URLSearchParams({
                    format: selectedFormat,
                    filename: filename
                });
                
                // Use direct fetch for file download since fetchApi in './js/utils.js' is designed for JSON
                // We need to handle the binary response differently
                const response = await fetch(`api/settings/user-data/export?${params.toString()}`);
                
                if (!response.ok) {
                    const errorText = await response.text();
                    throw new Error(`HTTP error! status: ${response.status}, message: ${errorText}`);
                }
                
                // Get the blob from the response
                const blob = await response.blob();
                
                // Extract filename from Content-Disposition header or use the provided filename
                let downloadFilename = `${filename}.${selectedFormat}`;
                const contentDisposition = response.headers.get('Content-Disposition');
                if (contentDisposition) {
                    const filenameMatch = contentDisposition.match(/filename=([^;]+)/);
                    if (filenameMatch) {
                        downloadFilename = filenameMatch[1].replace(/"/g, ''); // Remove quotes if present
                    }
                }
                
                // Create a download link
                const anchor = document.createElement('a');
                const url = window.URL.createObjectURL(blob);
                anchor.href = url;
                anchor.download = downloadFilename;
                anchor.style.display = 'none';
                document.body.appendChild(anchor);
                
                // Trigger download
                anchor.click();
                
                // Clean up
                window.URL.revokeObjectURL(url);
                document.body.removeChild(anchor);
                
                // Close the modal
                const modal = bootstrap.Modal.getInstance(document.getElementById('downloadModal'));
                modal.hide();
                
                // Show success message
                const successDiv = document.createElement('div');
                successDiv.className = 'alert alert-success alert-dismissible fade show mt-3';
                successDiv.innerHTML = `
                    <i class="bi bi-check-circle me-2"></i>
                    User data downloaded successfully as ${selectedFormat.toUpperCase()} format!
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                `;
                document.querySelector('.card-body').appendChild(successDiv);
                
            } catch (error) {
                console.error('Failed to download user data:', error);

                // Show error message in modal
                const alertDiv = document.createElement('div');
                alertDiv.className = 'alert alert-danger alert-dismissible fade show';
                alertDiv.innerHTML = `
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Failed to download user data: ${error.message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                `;
                document.querySelector('#downloadModal .modal-body').appendChild(alertDiv);

            } finally {
                // Reset button state
                confirmButton.disabled = false;
                confirmButton.innerHTML = originalHtml;
            }
        }

        /**
         * Handle import user data button click
         */
        async function handleImportUserData() {
            const fileInput = document.getElementById('importFile');
            const confirmButton = document.getElementById('confirmImport');
            const originalHtml = confirmButton.innerHTML;
            
            // Validate file selection
            if (!fileInput.files || fileInput.files.length === 0) {
                const alertDiv = document.createElement('div');
                alertDiv.className = 'alert alert-danger alert-dismissible fade show';
                alertDiv.innerHTML = `
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Please select a file to import.
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                `;
                document.querySelector('#importModal .modal-body').appendChild(alertDiv);
                return;
            }
            
            const file = fileInput.files[0];
            
            // Validate file extension
            const fileName = file.name.toLowerCase();
            const validExtensions = ['.zip', '.tar.gz', '.tar.xz'];
            const isValidFile = validExtensions.some(ext => fileName.endsWith(ext));
            
            if (!isValidFile) {
                const alertDiv = document.createElement('div');
                alertDiv.className = 'alert alert-danger alert-dismissible fade show';
                alertDiv.innerHTML = `
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Invalid file format. Please select a .zip, .tar.gz, or .tar.xz file.
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                `;
                document.querySelector('#importModal .modal-body').appendChild(alertDiv);
                return;
            }
            
            try {
                // Show loading state
                confirmButton.disabled = true;
                confirmButton.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Importing...';
                
                // Create FormData for file upload
                const formData = new FormData();
                formData.append('file', file);
                
                // Send the file to the import endpoint
                const response = await fetch('api/settings/user-data/import', {
                    method: 'POST',
                    body: formData
                });
                
                if (!response.ok) {
                    const errorText = await response.text();
                    throw new Error(`HTTP error! status: ${response.status}, message: ${errorText}`);
                }
                
                const result = await response.json();
                
                // Close the modal
                const modal = bootstrap.Modal.getInstance(document.getElementById('importModal'));
                modal.hide();
                
                // Show success message
                const successDiv = document.createElement('div');
                successDiv.className = 'alert alert-success alert-dismissible fade show mt-3';
                successDiv.innerHTML = `
                    <i class="bi bi-check-circle me-2"></i>
                    User data imported successfully! The page will reload to reflect the changes.
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                `;
                document.querySelector('.card-body').appendChild(successDiv);
                
                // Reset the form
                document.getElementById('importForm').reset();
                
                // Reload the page after a short delay to reflect the imported data
                setTimeout(() => {
                    window.location.reload();
                }, 2000);
                
            } catch (error) {
                console.error('Failed to import user data:', error);

                // Show error message in modal
                const alertDiv = document.createElement('div');
                alertDiv.className = 'alert alert-danger alert-dismissible fade show';
                alertDiv.innerHTML = `
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Failed to import user data: ${error.message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                `;
                document.querySelector('#importModal .modal-body').appendChild(alertDiv);

            } finally {
                // Reset button state
                confirmButton.disabled = false;
                confirmButton.innerHTML = originalHtml;
            }
        }

        /**
         * Handle delete user data button click
         */
        async function handleDeleteUserData() {
            const confirmButton = document.getElementById('confirmDelete');
            const originalHtml = confirmButton.innerHTML;
            
            try {
                // Show loading state
                confirmButton.disabled = true;
                confirmButton.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Deleting...';
                
                // Send DELETE request to the API
                const response = await fetch('api/settings/user-data/delete', {
                    method: 'DELETE'
                });
                
                if (!response.ok) {
                    const errorText = await response.text();
                    throw new Error(`HTTP error! status: ${response.status}, message: ${errorText}`);
                }
                
                const result = await response.json();
                
                // Close the modal
                const modal = bootstrap.Modal.getInstance(document.getElementById('deleteModal'));
                modal.hide();
                
                // Show success message
                const successDiv = document.createElement('div');
                successDiv.className = 'alert alert-success alert-dismissible fade show mt-3';
                successDiv.innerHTML = `
                    <i class="bi bi-check-circle me-2"></i>
                    All user data has been deleted successfully! The page will reload to reflect the changes.
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                `;
                document.querySelector('.card-body').appendChild(successDiv);
                
                // Reset the confirmation input
                document.getElementById('deleteConfirmationInput').value = '';
                
                // Reload the page after a short delay to reflect the changes
                setTimeout(() => {
                    window.location.reload();
                }, 2000);
                
            } catch (error) {
                console.error('Failed to delete user data:', error);

                // Show error message in modal
                const alertDiv = document.createElement('div');
                alertDiv.className = 'alert alert-danger alert-dismissible fade show';
                alertDiv.innerHTML = `
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Failed to delete user data: ${error.message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                `;
                document.querySelector('#deleteModal .modal-body').appendChild(alertDiv);

            } finally {
                // Reset button state
                confirmButton.disabled = true; // Keep disabled until user types "DELETE" again
                confirmButton.innerHTML = originalHtml;
            }
        }

        // Set up event listeners when DOM is loaded
        document.addEventListener('DOMContentLoaded', () => {            
            const confirmDownloadButton = document.getElementById('confirmDownload');
            confirmDownloadButton.addEventListener('click', handleDownloadUserData);

            const confirmImportButton = document.getElementById('confirmImport');
            confirmImportButton.addEventListener('click', handleImportUserData);

            const confirmDeleteButton = document.getElementById('confirmDelete');
            confirmDeleteButton.addEventListener('click', handleDeleteUserData);

            // Handle delete confirmation input
            const deleteConfirmationInput = document.getElementById('deleteConfirmationInput');
            deleteConfirmationInput.addEventListener('input', () => {
                const confirmButton = document.getElementById('confirmDelete');
                if (deleteConfirmationInput.value === 'DELETE') {
                    confirmButton.disabled = false;
                } else {
                    confirmButton.disabled = true;
                }
            });

            // Clear any existing alerts and set default filename when the download modal is shown
            document.getElementById('downloadModal').addEventListener('show.bs.modal', () => {
                const existingAlerts = document.querySelectorAll('#downloadModal .alert');
                existingAlerts.forEach(alert => alert.remove());

                // Set default filename
                document.getElementById('filename').value = generateDefaultFilename();
            });

            // Clear any existing alerts when the import modal is shown
            document.getElementById('importModal').addEventListener('show.bs.modal', () => {
                const existingAlerts = document.querySelectorAll('#importModal .alert');
                existingAlerts.forEach(alert => alert.remove());

                // Reset the form
                document.getElementById('importForm').reset();
            });

            // Clear any existing alerts and reset form when the delete modal is shown
            document.getElementById('deleteModal').addEventListener('show.bs.modal', () => {
                const existingAlerts = document.querySelectorAll('#deleteModal .alert');
                existingAlerts.forEach(alert => alert.remove());

                // Reset the confirmation input
                document.getElementById('deleteConfirmationInput').value = '';
                document.getElementById('confirmDelete').disabled = true;
            });
        });
    </script>
</body>
</html>

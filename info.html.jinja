<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="{{ PROJECT_NAME }} - Information">

    <title>{{ PROJECT_NAME }} - Information</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">  <!-- See https://icons.getbootstrap.com/#install -->

    <!-- Custom CSS -->
    <link href="css/styles.css" rel="stylesheet">
</head>
<body>
    <main class="container">
        <div id="info"></div>
    </main>

    <!-- Bootstrap JS and dependencies -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    <!-- Components -->
    <script src="js/navbar.js"></script>

    <script>
        async function fetchInfo() {
            try {
                const response = await fetch('api/info', {
                    headers: {
                        'Accept': 'application/json'
                    }
                });
                if (!response.ok) {
                    throw new Error('Network response was not ok ' + response.statusText);
                }
                const msg = await response.json();
                displayInfo(msg);
            } catch (error) {
                console.error('There has been a problem with your fetch operation:', error);
            }
        }

        function displayInfo(msg) {
            const elem = document.getElementById('info');
            // Format the dictionary as "key : value" lines
            elem.textContent = Object.entries(msg)
                .map(([key, value]) => `${key} : ${value}`)
                .join('\n');
        }

        // Fetch and display info when the page loads
        window.onload = fetchInfo;
    </script>
</body>
</html>
